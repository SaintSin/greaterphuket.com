---
// src/components/global/ConsentBanner.astro
---

<div
  id="consent-banner"
  class="consent-banner"
  role="region"
  aria-label="Cookie consent"
  inert
>
  <div class="consent-content">
    <p>
      We use analytics to understand how visitors use our site and to improve
      your experience. See our <a href="/privacy-policy/">privacy policy</a>.
    </p>
    <div class="consent-buttons">
      <button type="button" id="consent-accept">Accept analytics</button>
      <button type="button" id="consent-reject" class="secondary">Reject</button>
    </div>
  </div>
</div>

<script>
  const STORAGE_KEY = 'analytics-consent';
  let abortController: AbortController | null = null;

  function initBanner() {
    abortController?.abort();
    abortController = new AbortController();
    const { signal } = abortController;

    const banner = document.getElementById('consent-banner');
    if (!banner) return;

    const status = localStorage.getItem(STORAGE_KEY);

    if (status === 'true') {
      (window as Window & { grantConsent?: () => void }).grantConsent?.();
    } else if (status !== 'false') {
      banner.classList.add('is-visible');
      banner.removeAttribute('inert');
    }

    function dismiss() {
      banner!.classList.remove('is-visible');
      banner!.setAttribute('inert', '');
    }

    document.getElementById('consent-accept')?.addEventListener('click', () => {
      localStorage.setItem(STORAGE_KEY, 'true');
      (window as Window & { grantConsent?: () => void }).grantConsent?.();
      dismiss();
    }, { signal });

    document.getElementById('consent-reject')?.addEventListener('click', () => {
      localStorage.setItem(STORAGE_KEY, 'false');
      dismiss();
    }, { signal });
  }

  document.addEventListener('astro:page-load', initBanner);
  if (document.readyState !== 'loading') {
    initBanner();
  } else {
    document.addEventListener('DOMContentLoaded', initBanner, { once: true });
  }
</script>

<style>
  .consent-banner {
    position: fixed;
    inset: auto 0 0 0;
    width: 100%;
    border: none;
    background: var(--color-dark-glare, #1a1a2e);
    color: var(--color-light, #f5f5f5);
    padding: var(--space-s, 1rem);
    box-shadow: 0 -2px 12px oklch(0% 0 0 / 40%);
    z-index: 100;
    transform: translateY(100%);
    transition: transform 0.4s ease-out;
    pointer-events: none;
  }

  .consent-banner.is-visible {
    transform: translateY(0);
    pointer-events: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .consent-banner {
      transition: none;
    }
  }

  .consent-content {
    max-width: var(--wrapper-max-width, 80rem);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-m, 1.5rem);
  }

  .consent-content p {
    margin: 0;
    font-size: var(--step--1, 0.875rem);
    line-height: 1.5;
    flex: 1;
  }

  .consent-content a {
    color: inherit;
  }

  .consent-buttons {
    display: flex;
    gap: var(--space-xs, 0.5rem);
    flex-shrink: 0;
  }

  button {
    padding: var(--space-2xs, 0.25rem) var(--space-s, 1rem);
    border: none;
    border-radius: 0.25rem;
    cursor: pointer;
    font-size: var(--step--1, 0.875rem);
    font-weight: 500;
    transition: opacity 0.2s ease;
    white-space: nowrap;
    background: var(--color-secondary, #b9933b);
    color: var(--color-dark, #111);
  }

  button:hover {
    opacity: 0.85;
  }

  button.secondary {
    background: transparent;
    color: var(--color-light, #f5f5f5);
    border: 1px solid oklch(100% 0 0 / 40%);
  }

  button.secondary:hover {
    border-color: var(--color-light, #f5f5f5);
    opacity: 1;
  }

  @media (max-width: 48rem) {
    .consent-content {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-s, 1rem);
    }

    .consent-buttons {
      width: 100%;
    }

    button {
      flex: 1;
    }
  }
</style>
