{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"],
	"compilerOptions": {
		"baseUrl": ".",
		"moduleResolution": "bundler",
		"paths": {
			"@assets/*": ["src/assets/*"],
			"@components/*": ["src/components/*"],
			"@config/*": ["src/config/*"],
			"@images/*": ["src/assets/images/*"],
			"@layouts/*": ["src/layouts/*"],
			"@data/*": ["src/data/*"],
			"@scripts/*": ["src/scripts/*"],
			"@styles/*": ["src/styles/*"],
			"@types": ["src/types"],
			"@utils/*": ["src/utils/*"]
		}
	}
}
